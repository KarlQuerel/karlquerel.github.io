# Firebase web app config. These are public client identifiers (shipped to the
# browser), not secrets — but they live here so they stay out of source per the
# project convention. Copy to `.env` and fill in for local dev / deploy.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
