{
  "name": "karlquerel.github.io",
  "version": "1.0.0",
  "description": "Personal portfolio website - retro pixel aesthetic (Vue 3 + Vite)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "cp dist/index.html dist/404.html",
    "serve": "vite preview",
    "test": "playwright test",
    "deploy": "vite build && cp dist/index.html dist/404.html && gh-pages -d dist",
    "format": "prettier --write \"src/**/*.{js,vue,css,scss}\" --config .prettierrc && npm run lint:fix && npm run format:check && npm run lint:check",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,scss}\" --config .prettierrc",
    "lint": "eslint . --ext .js,.vue --cache",
    "lint:fix": "eslint . --ext .js,.vue --cache --fix",
    "lint:check": "eslint . --ext .js,.vue --cache --max-warnings 0",
    "clean": "npm run lint:fix && npm run format",
    "prepare": "simple-git-hooks"
  },
  "author": "Karl Querel",
  "license": "SEE LICENSE IN LICENSE",
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --cache --fix",
      "prettier --write --config .prettierrc"
    ],
    "*.{css,scss}": "prettier --write --config .prettierrc"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/eslint-parser": "^7.23.10",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^9.33.0",
    "gh-pages": "^6.3.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.6.2",
    "sass": "^1.85.0",
    "simple-git-hooks": "^2.13.1",
    "terser": "^5.43.1",
    "vite": "^6.3.4"
  },
  "dependencies": {
    "firebase": "^11.3.1",
    "typeit": "^8.7.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  }
}
